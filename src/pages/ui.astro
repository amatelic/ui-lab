<SectionScreen
    title="Card inverted"
    description="Basic css inverted example"
    code={`<Card title="Card inverted" description="Basic css inverted example" />`}
>
    <CardHover>
        <div class="positioning-context">
            <div class="parent card-black">
                <div class="card-chip"></div>
                <div class="card-number">3782 8224 6310 004</div>
                <div class="card-holder">Asta UI</div>
                <div class="card-brand">AMEX</div>
            </div>
        </div>
    </CardHover>
    <!-- <style>
    body {
        font-family: "Inter Variable", sans-serif;
    }
</style> -->
</SectionScreen>

<style>
    .positioning-context {
        position: relative;
        width: inherit;
        height: inherit;
        padding: 12px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 1000px;
        color: white;
    }
    .parent {
        width: inherit;
        height: inherit;
        border-radius: 12px;
        /*padding: 20px;*/
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        transform-style: preserve-3d;
        transition: transform 0.3s;
        color: white;
        overflow: hidden;
        transform: rotateY(5deg);
    }
    .parent:hover {
        transform: rotateY(0) translateY(-4px);
    }
    .parent * {
        color: white;
    }
    .parent::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 12px;
        background:
            linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.08) 1px,
                transparent 1px
            );
        background-size: 20px 20px;
        z-index: 0;
    }
    .card-black {
        background: linear-gradient(135deg, #333, #111);
        inset: 0 20px 20px 0;
        color: white;
    }
    .card-chip {
        position: absolute;
        top: 20px;
        left: 20px;
        width: 40px;
        height: 30px;
        background: #c0c0c0;
        border-radius: 4px;
        box-shadow: inset 0 0 3px rgba(0, 0, 0, 0.3);
    }
    .card-number {
        position: absolute;
        bottom: 40px;
        left: 20px;
        font-size: 14px;
        letter-spacing: 2px;
    }
    .card-brand {
        position: absolute;
        bottom: 15px;
        right: 20px;
        font-size: 24px;
        font-weight: bold;
    }
    .card-holder {
        position: absolute;
        bottom: 20px;
        left: 20px;
        font-size: 12px;
        text-transform: uppercase;
    }
</style>
