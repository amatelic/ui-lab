    <script>
        // Utility: clamp
        const clamp = (n, min, max) => Math.min(max, Math.max(min, n));

        // ASCII Statue Renderer
        (function () {
            const pre = document.getElementById("ascii");
            const fpsEl = document.getElementById("fps");
            const toggleMotion = document.getElementById("toggleMotion");

            let animationId = null;
            let running = true;
            let reduceMotion = window.matchMedia(
                "(prefers-reduced-motion: reduce)",
            ).matches;

            // Build grid cache for performance
            function buildGrid(cols, rows) {
                // Compute geometry parameters relative to the ASCII grid
                const cx = Math.floor(cols * 0.5);
                const top = Math.floor(rows * 0.06);

                const aBody = cols * 0.3; // bust semi-axis x
                const bBody = rows * 0.34; // bust semi-axis y
                const cyBody = rows * 0.42;

                const aHead = cols * 0.18;
                const bHead = rows * 0.2;
                const cyHead = rows * 0.18;

                // Base / pedestal parameters
                const baseTop = Math.floor(rows * 0.72);
                const baseHeight = Math.max(4, Math.floor(rows * 0.14));
                const baseWidthCols = Math.floor(cols * 0.56);
                const baseLeft = Math.floor(cx - baseWidthCols / 2);
                const baseRight = baseLeft + baseWidthCols;

                // Capital (top slab)
                const capWidth = Math.floor(baseWidthCols * 0.82);
                const capLeft = Math.floor(cx - capWidth / 2);
                const capRight = capLeft + capWidth;
                const capTop = baseTop - Math.max(2, Math.floor(rows * 0.03));

                // Characters for tone
                const ramp = [" ", ".", ":", "-", "=", "+", "*", "#", "%", "@"];

                // Some subtle noise to avoid banding
                const noise = new Float32Array(cols * rows);
                for (let i = 0; i < noise.length; i++) {
                    noise[i] = (Math.sin(i * 12.9898) * 43758.5453) % 1;
                }

                function shade(x, y) {
                    // Base stone (bust + head)
                    const ebBody =
                        Math.pow((x - cx) / aBody, 2) +
                        Math.pow((y - cyBody) / bBody, 2);
                    const ebHead =
                        Math.pow((x - cx) / aHead, 2) +
                        Math.pow((y - cyHead) / bHead, 2);
                    let inside = ebBody <= 1.0 || ebHead <= 1.0;

                    // Carve a slight collar between head and body ( concave dip )
                    if (y > cyBody - bBody * 0.35 && y < cyHead + bHead * 0.2) {
                        const collar =
                            Math.pow(
                                (y - (cyHead + bHead * 0.18)) / (bBody * 0.35),
                                2,
                            ) + Math.pow((x - cx) / (aBody * 0.65), 2);
                        if (collar < 1.0) inside = true; // ensure silhouette continuity
                    }

                    // Pedestal regions
                    const inCap =
                        y >= capTop &&
                        y <= capTop + 1 &&
                        x >= capLeft &&
                        x <= capRight;
                    const inBase =
                        y >= baseTop &&
                        y < baseTop + baseHeight &&
                        x >= baseLeft &&
                        x <= baseRight;

                    let v = 0; // density / intensity
                    if (inside) {
                        // Shade using a soft lighting model
                        const lx = -0.55,
                            ly = -0.35; // "light" from top-left
                        const nxBody = (x - cx) / (aBody || 1);
                        const nyBody = (y - cyBody) / (bBody || 1);
                        const nxHead = (x - cx) / (aHead || 1);
                        const nyHead = (y - cyHead) / (bHead || 1);
                        const nx = ebBody < 1 ? nxBody : nxHead;
                        const ny = ebBody < 1 ? nyBody : nyHead;
                        const nDotL = clamp(
                            (-(nx * lx + ny * ly) + 1) / 2,
                            0,
                            1,
                        );
                        v = 0.35 + 0.65 * Math.pow(nDotL, 1.2);
                    } else if (inCap || inBase) {
                        // Base is darker stone
                        v = 0.25 + 0.2 * Math.random();
                    }

                    // Subtle marble veining noise
                    if (v > 0) {
                        const idx = y * cols + x;
                        v = clamp(v + (noise[idx] - 0.5) * 0.12, 0, 1);
                    }

                    return v;
                }

                // Precompute cell info for rendering
                const cells = new Array(rows);
                for (let y = 0; y < rows; y++) {
                    const row = new Array(cols);
                    for (let x = 0; x < cols; x++) {
                        const v = shade(x, y);
                        const tone =
                            v > 0
                                ? ramp[
                                      Math.min(
                                          ramp.length - 1,
                                          Math.floor(v * (ramp.length - 1)),
                                      )
                                  ]
                                : " ";
                        row[x] = { v, tone };
                    }
                    cells[y] = row;
                }

                return { cells, cols, rows, cx, top, baseTop, capTop };
            }

            function renderFrame(grid, frameIdx) {
                // Slight breathing / lighting shift per frame
                const cols = grid.cols,
                    rows = grid.rows;
                let out = "";
                const frames = 3; // discrete light angles
                const phase = frameIdx % frames;

                for (let y = 0; y < rows; y++) {
                    for (let x = 0; x < cols; x++) {
                        const c = grid.cells[y][x];
                        if (c.v === 0) {
                            out += " ";
                            continue;
                        }

                        // Rotate the "light" around the statue for 3 frames
                        const s =
                            (Math.sin((x + y + phase * 3) * 0.22) + 1) * 0.5; // 0..1
                        const mixed = clamp(c.v * (0.78 + 0.22 * s), 0, 1);
                        const idx = Math.min(
                            ramp.length - 1,
                            Math.floor(mixed * (ramp.length - 1)),
                        );
                        out += ramp[idx];
                    }
                    if (y < rows - 1) out += "\n";
                }
                return out;
            }

            // Responsive sizing
            function computeGridSize() {
                // Base size scales with viewport; clamp for readability
                const vw = Math.max(320, window.innerWidth);
                const cols =
                    vw < 520 ? 68 : vw < 900 ? 86 : vw < 1300 ? 104 : 118;
                const rows = clamp(Math.floor(cols * 0.42), 30, 60);
                return { cols, rows };
            }

            let grid = buildGrid(...Object.values(computeGridSize()));

            function draw(frame = 0) {
                pre.textContent = renderFrame(grid, frame);
            }

            // Animation loop with FPS display
            let last = performance.now();
            let acc = 0;
            let frames = 0;
            let rafId = 0;

            function loop(now) {
                if (!running) return;
                const dt = now - last;
                last = now;
                acc += dt;
                frames++;

                // Update FPS approx every 500ms
                if (acc > 500) {
                    const fps = Math.round((frames * 1000) / acc);
                    fpsEl.textContent = fps + " fps";
                    acc = 0;
                    frames = 0;
                }

                // Render at ~18 fps for a crisp, low-power animation
                const targetMs = 1000 / 18;
                if (!loop.next || now >= loop.next) {
                    loop.next = now + targetMs;
                    draw(Math.floor(now / targetMs) % 3);
                }

                rafId = requestAnimationFrame(loop);
            }

            function start() {
                if (reduceMotion || !toggleMotion.checked) {
                    running = false;
                    cancelAnimationFrame(rafId);
                    draw(0);
                    return;
                }
                if (!running) {
                    running = true;
                    last = performance.now();
                    rafId = requestAnimationFrame(loop);
                }
            }

            function stop() {
                running = false;
                cancelAnimationFrame(rafId);
            }

            toggleMotion.addEventListener("change", () => {
                if (toggleMotion.checked) start();
                else stop();
            });

            window.addEventListener("resize", () => {
                const size = computeGridSize();
                grid = buildGrid(size.cols, size.rows);
                draw(0);
            });

            // Reduced motion support
            const media = window.matchMedia("(prefers-reduced-motion: reduce)");
            media.addEventListener?.("change", (e) => {
                reduceMotion = e.matches;
                if (reduceMotion) {
                    toggleMotion.checked = false;
                    stop();
                } else {
                    toggleMotion.checked = true;
                    start();
                }
            });
            if (reduceMotion) {
                toggleMotion.checked = false;
            }

            // Kick off
            draw(0);
            if (toggleMotion.checked && !reduceMotion) start();

            // Footer year
            document.getElementById("year").textContent =
                new Date().getFullYear();
        })();

        // Fake dialog trigger just for demo
        (function demoDialog() {
            const btn = document.getElementById("openDialog");
            if (!btn) return;
            btn.addEventListener("click", () => {
                alert("Aether UI Dialog demo — hook your real dialog here!");
            });
        })();
    </script>

